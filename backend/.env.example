# Copy this file to backend/.env.local for machine-local development only.
# Do not commit the local backend/.env.local copy.

# Server
# Canonical repo-tracked local backend port.
# Use PORT=8081 only as an explicit machine-local tunnel override.
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=trashbounty
DB_PASSWORD=your_strong_password_here
DB_NAME=trashbounty_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=ganti_dengan_32_karakter_random_yang_aman

# OpenAI
OPENAI_API_KEY=sk-...
GPT_MINI_MODEL=gpt-5.4-mini
GPT_STANDARD_MODEL=gpt-4o
GPT_CHAT_MODEL=gpt-5.4-mini

# Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10

# App
APP_ENV=development
