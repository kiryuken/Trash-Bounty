# Copy this file to agents/.env.local for machine-local development only.
# Do not commit the local agents/.env.local copy.
TELEGRAM_BOT_TOKEN=
# Canonical local backend URL for repo-tracked agents development.
# Use port 8081 only if you explicitly launched a tunnel-only local override.
TRASHBOUNTY_API_URL=http://localhost:8080
TRASHBOUNTY_INTERNAL_SECRET=trashbounty_internal_secret
PORT=8000